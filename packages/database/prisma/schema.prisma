// =============================================================================
// SZDevs - Prisma schema
//
// Initial version: authentication & permissions domain only.
// Future modules (RH, Financeiro, Projetos, etc.) will be added in
// subsequent migrations.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum PermissionModule {
  AUTH
  RH
  FINANCEIRO
  PROJETOS
  SUPORTE
  PAGAMENTOS
  LICENCAS
  DEVOPS
  DEVELOPER
  INTEGRATIONS
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

// -----------------------------------------------------------------------------
// Core identity
// -----------------------------------------------------------------------------

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  name             String
  passwordHash     String
  avatarUrl        String?
  emailVerified    Boolean    @default(false)
  emailVerifiedAt  DateTime?
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?
  status           UserStatus @default(ACTIVE)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  roles              UserRole[]
  extraPermissions   UserPermission[]
  sessions           Session[]
  auditLogs          AuditLog[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  oauthAccounts      OAuthAccount[]

  // Relations where this user is the one performing the assignment
  rolesAssigned       UserRole[]       @relation("UserRoleAssignedBy")
  permissionsAssigned UserPermission[] @relation("UserPermissionAssignedBy")

  // Inverse of Employee.userId — each User may have at most one employee
  // profile in the RH module. Users without an employee profile are
  // typically admins / devs without an HR record.
  employee Employee?

  // Projects module — every relation a user can have to a Project.
  // Six named relations because Project / Task / TimeEntry each
  // touch User from multiple sides (owner, client, assignee,
  // reporter, member, time logger).
  projectsOwned      Project[]       @relation("ProjectOwner")
  projectsAsClient   Project[]       @relation("ProjectClient")
  projectMemberships ProjectMember[]
  tasksAssigned      Task[]          @relation("TaskAssignee")
  tasksReported      Task[]          @relation("TaskReporter")
  timeEntries        TimeEntry[]

  // Finance module — the user may play three roles against
  // finance records. Named relations because FinanceTransaction
  // only touches the creator, while Invoice touches both the
  // client (billed party) and the creator (issuer), so a single
  // unnamed relation would clash.
  financeTransactionsCreated FinanceTransaction[] @relation("FinanceTransactionCreator")
  invoicesAsClient           Invoice[]            @relation("InvoiceClient")
  invoicesCreated            Invoice[]            @relation("InvoiceCreator")

  // Notifications module — in-app notifications addressed to
  // this user. Cascade on delete so removing a user also removes
  // their notification inbox (no orphan rows).
  notifications Notification[]

  // Support module — a user can open tickets, be assigned to
  // tickets, and author messages on tickets. Named relations
  // because Ticket touches User from multiple sides (client,
  // assignee) and we need Prisma to disambiguate.
  ticketsOpened   Ticket[]        @relation("TicketClient")
  ticketsAssigned Ticket[]        @relation("TicketAssignee")
  ticketMessages  TicketMessage[] @relation("TicketMessageAuthor")

  // DevOps module — a user may execute deployments. Restricted
  // FK on delete so the audit trail survives user removal.
  deploymentsTriggered Deployment[] @relation("DeploymentDeployedBy")

  // Payments module — subscriptions and payment history.
  subscriptions Subscription[]
  payments      Payment[]

  // License module — product bindings, tokens issued/revoked, activations.
  clientProductBindings   ClientProductBinding[] @relation("LicenseClient")
  productBindingsGranted  ClientProductBinding[] @relation("LicenseAssignedBy")
  activationTokensOwned   ActivationToken[]      @relation("TokenClient")
  activationTokensIssued  ActivationToken[]      @relation("TokenIssuedBy")
  activationTokensRevoked ActivationToken[]      @relation("TokenRevokedBy")

  // VPS management module — a user can be the client a VPS is
  // attached to OR the operator who attached it. Two named relations
  // because both FKs target User.
  clientVps   ClientVPS[] @relation("ClientVPSClient")
  vpsAttached ClientVPS[] @relation("ClientVPSAttachedBy")

  // Recurring billing module — a user can be the billed client or
  // the staff member who created the recurring subscription.
  recurringSubscriptionsAsClient  RecurringSubscription[] @relation("RecurringSubClient")
  recurringSubscriptionsCreated   RecurringSubscription[] @relation("RecurringSubCreator")

  // 2FA recovery codes — one-time bypass codes the user can use
  // when they lose access to their authenticator app. Each code is
  // stored hashed (bcrypt) so a DB leak doesn't expose live codes.
  recoveryCodes TwoFactorRecoveryCode[]

  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model Role {
  id                   String   @id @default(cuid())
  name                 String   @unique
  description          String?
  isSystem             Boolean  @default(false)
  requireEmailVerified Boolean  @default(false)
  require2FA           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  module      PermissionModule
  createdAt   DateTime         @default(now())

  roles RolePermission[]
  users UserPermission[]

  @@index([module])
  @@map("permissions")
}

// -----------------------------------------------------------------------------
// Join tables
// -----------------------------------------------------------------------------

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedBy String?
  assignedAt DateTime @default(now())

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@index([roleId])
  @@index([assignedBy])
  @@map("user_roles")
}

/// Extra permission granted directly to a user (bypasses role).
model UserPermission {
  userId       String
  permissionId String
  assignedBy   String?
  assignedAt   DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assigner   User?      @relation("UserPermissionAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, permissionId])
  @@index([permissionId])
  @@index([assignedBy])
  @@map("user_permissions")
}

// -----------------------------------------------------------------------------
// Sessions & tokens
// -----------------------------------------------------------------------------

model Session {
  id           String    @id @default(uuid())
  userId       String
  token        String    @unique
  refreshToken String    @unique
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  lastSeenAt   DateTime?
  revokedAt    DateTime?
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// One-time bypass code generated when 2FA is enabled (or
/// explicitly regenerated by the user). The plaintext value is
/// shown ONCE at generation time and never persisted; we keep
/// only the bcrypt hash. When the user verifies a code it is
/// marked `usedAt` so it cannot be replayed.
model TwoFactorRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor_recovery_codes")
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String        @unique
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// -----------------------------------------------------------------------------
// Audit
// -----------------------------------------------------------------------------

model AuditLog {
  id         String           @id @default(cuid())
  userId     String?
  action     String
  module     PermissionModule
  resourceId String?
  meta       Json             @default("{}")
  ipAddress  String?
  /// Browser / client User-Agent header. Stored verbatim — useful for
  /// post-incident forensics (identify device type, browser, OS) without
  /// needing to join the sessions table (which may already be revoked).
  userAgent  String?
  /// The session that performed this action. Lets you pull all audit events
  /// for a given session (e.g. after revoking a compromised session to see
  /// exactly what it did) and correlate AuditLog with Session.userAgent.
  sessionId  String?
  createdAt  DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([userId, module])
  @@index([sessionId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// RH module — employees, positions, departments, documents.
//
// Migration name: add_rh_module
//
// Design notes:
//   - Employee.userId is nullable — not every person on HR's roster has
//     a platform account. The link is a soft reference via SetNull so
//     deleting a user keeps the employee row but detaches it.
//   - Department.managerId points at an Employee (circular with
//     Employee.department), resolved via a named relation pair. Both
//     sides use SetNull on delete so the graph never cascades out of
//     control when a manager leaves.
//   - Employee.managerId is a self-reference for the org hierarchy.
//   - VacationRequest and PerformanceReview are declared as minimal
//     stubs here so Employee's forward relations resolve cleanly.
//     They get fleshed out in their own modules in future turns.
// =============================================================================

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  DISMISSED
}

enum PositionLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
}

enum EmployeeDocumentType {
  CONTRACT
  ID
  CERTIFICATE
  OTHER
}

model Employee {
  id          String         @id @default(cuid())
  /// Optional soft link to a platform user. A person can exist in HR
  /// without ever having an auth account, and a user can be deleted
  /// without losing their employee row (SetNull).
  userId      String?        @unique
  name        String
  email       String         @unique
  phone       String?
  cpf         String         @unique
  birthDate   DateTime       @db.Date
  hireDate    DateTime       @db.Date
  dismissDate DateTime?      @db.Date
  status      EmployeeStatus @default(ACTIVE)

  positionId   String
  departmentId String
  /// Self-reference for the org hierarchy. Nullable so the CEO (or a
  /// freshly created employee with no manager yet) can have a null
  /// here without breaking the relation.
  managerId    String?

  /// Individual salary for this employee (Decimal so there's no floating-
  /// point drift on payroll math). Position.salary is the band reference;
  /// this column holds the actual negotiated value that feeds the Financeiro
  /// module's automated payroll lancamentos.
  salary       Decimal?      @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ---- Relations ----
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  position   Position   @relation(fields: [positionId], references: [id], onDelete: Restrict)
  department Department @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: Restrict)

  manager      Employee?  @relation("EmployeeHierarchy", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates Employee[] @relation("EmployeeHierarchy")

  documents          EmployeeDocument[]
  performanceReviews PerformanceReview[]

  // Vacation requests this employee has submitted.
  vacationRequests         VacationRequest[] @relation("VacationRequester")
  // Vacation requests this employee has reviewed (approved/rejected).
  // Separate named relation from the requester side so Prisma can
  // disambiguate the two FKs on the same target table.
  vacationRequestsReviewed VacationRequest[] @relation("VacationReviewer")

  // Work schedules assigned to this employee over time. The current
  // one is whichever has the latest `effectiveFrom <= now()`.
  workSchedules WorkSchedule[]

  // Inverse of Department.managerId — this employee may manage zero
  // or more departments. Named so Prisma can disambiguate from the
  // DepartmentEmployees relation above.
  managedDepartments Department[] @relation("DepartmentManager")

  @@index([status])
  @@index([departmentId])
  @@index([positionId])
  @@index([managerId])
  @@index([hireDate])
  @@map("rh_employees")
}

model Position {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  level       PositionLevel
  /// Nullable so HR can create a position before the band has been
  /// finalized. `Decimal(12, 2)` covers R$ 999,999,999.99 which is
  /// comfortably beyond any real salary.
  salary      Decimal?      @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@index([level])
  @@map("rh_positions")
}

model Department {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  /// The manager IS an employee (SetNull on delete so removing an
  /// employee doesn't cascade into the department row). Optional
  /// because freshly created departments may not have a manager yet.
  managerId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manager   Employee?  @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees Employee[] @relation("DepartmentEmployees")

  @@index([managerId])
  @@map("rh_departments")
}

model EmployeeDocument {
  id         String               @id @default(cuid())
  employeeId String
  name       String
  type       EmployeeDocumentType @default(OTHER)
  /// Opaque key into the `@szdevs/storage` adapter (R2 or local).
  /// The storage adapter resolves this to the real object at download
  /// time — this column is intentionally format-agnostic so swapping
  /// R2 for another S3 provider requires no schema change.
  fileKey    String
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime             @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([type])
  @@map("rh_employee_documents")
}

// -----------------------------------------------------------------------------
// Vacations + absences (migration: add_rh_vacations)
// -----------------------------------------------------------------------------

enum VacationRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum VacationRequestType {
  VACATION
  SICK_LEAVE
  PERSONAL
  MATERNITY
  PATERNITY
  OTHER
}

/// Vacation / absence request. Covers both planned vacations and
/// ad-hoc absences (sick leave, personal, parental) under a single
/// model, discriminated by the `type` enum. The whole lifecycle
/// (request → review → approval/rejection → cancellation) is tracked
/// in-place on the same row so HR can audit every decision without
/// a separate history table.
model VacationRequest {
  id         String                @id @default(cuid())
  employeeId String
  type       VacationRequestType   @default(VACATION)
  startDate  DateTime              @db.Date
  endDate    DateTime              @db.Date
  /// Number of business days the request covers — computed by the
  /// service (excluding weekends) when the row is created. Stored
  /// rather than recomputed on every read so queries that filter by
  /// "days off this year" stay fast.
  daysCount  Int
  status     VacationRequestStatus @default(PENDING)

  /// When the employee submitted the request. Renamed from the old
  /// `createdAt` so the column name tells the whole story.
  requestedAt     DateTime  @default(now())
  /// When the review decision (approve/reject) was recorded. Null
  /// while the request is still PENDING.
  reviewedAt      DateTime?
  /// FK to the reviewing employee. Nullable both because it's unset
  /// while PENDING and because the reviewer may be deleted later
  /// (SetNull) without losing the rest of the audit trail.
  reviewedById    String?
  /// Free-text notes submitted by the requester, e.g. "trip to family
  /// wedding". Optional.
  notes           String?
  /// Populated only when the request is REJECTED — the reviewer's
  /// explanation, surfaced to the employee via the notification.
  rejectionReason String?
  updatedAt       DateTime  @updatedAt

  employee   Employee  @relation("VacationRequester", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy Employee? @relation("VacationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([status])
  @@index([type])
  @@index([startDate, endDate])
  @@index([reviewedById])
  @@map("rh_vacation_requests")
}

/// Weekly work schedule for an employee. A new row is created every
/// time the schedule changes — the "current" schedule is whichever
/// row has the latest `effectiveFrom <= now()`. Previous rows are
/// never updated or deleted, giving HR an immutable history.
///
/// Each day stores the number of HOURS the employee is expected to
/// work. `0` means "day off" (weekends or a shortened week).
/// Int (not Decimal) because SZDevs's schedules never need
/// sub-hour precision and integers are cheaper to compare.
model WorkSchedule {
  id         String @id @default(cuid())
  employeeId String

  monday    Int @default(0)
  tuesday   Int @default(0)
  wednesday Int @default(0)
  thursday  Int @default(0)
  friday    Int @default(0)
  saturday  Int @default(0)
  sunday    Int @default(0)

  /// First date this schedule applies. The service enforces
  /// uniqueness per (employeeId, effectiveFrom) to prevent two
  /// schedules from claiming the same start date.
  effectiveFrom DateTime @db.Date
  /// Optional free-text explanation — "reduced hours during maternity
  /// leave", "remote Fridays", etc.
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, effectiveFrom])
  @@index([employeeId])
  @@index([effectiveFrom])
  @@map("rh_work_schedules")
}

model PerformanceReview {
  id         String   @id @default(cuid())
  employeeId String
  reviewerId String?
  /// Period label, e.g. "2026-Q1" or "2026-H1". Kept as text rather
  /// than two dates because review cadence differs across departments.
  period     String
  score      Float?
  feedback   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([period])
  @@map("rh_performance_reviews")
}

// =============================================================================
// Projects module — projects, sprints, kanban boards, tasks, time tracking.
//
// Migration name: add_projects_module
//
// Performance design:
//   - Tasks carry an `order` int per column so the board query can
//     return them sorted with a single index lookup. The `(columnId,
//     order)` composite index is the hot path — every drag-and-drop
//     and every board fetch uses it.
//   - The board endpoint (`GET /projects/:id/board`) issues ONE
//     Prisma query with nested includes — Prisma's join planner
//     resolves it into 2-3 batched SQL queries (board → columns →
//     tasks), never N+1 per task.
//   - `(boardId, order)` on Column for the column-ordering query.
//   - Composite `(projectId, status)` on Project + Sprint for the
//     "active sprint" lookup, which the burndown endpoint hits.
//   - `(taskId, date)` on TimeEntry for the per-day burndown rollup.
// =============================================================================

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectMemberRole {
  OWNER
  MANAGER
  DEVELOPER
  DESIGNER
  QA_ENGINEER
  SECURITY_ENGINEER
  DEVOPS
  VIEWER
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum TaskType {
  STORY
  BUG
  TASK
  EPIC
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime      @db.Date
  /// Nullable for open-ended projects with no committed end date.
  endDate     DateTime?     @db.Date

  /// Optional client (a User in the auth domain). Internal projects
  /// have no client. SetNull on user delete so the project history
  /// survives a user being removed.
  clientId String?
  /// Project owner — the principal accountable person. Required.
  /// Restricted on delete so we never orphan a project; admins must
  /// reassign ownership before deleting a user.
  ownerId  String

  /// Optional GitHub repository URL (e.g. "https://github.com/org/repo").
  /// Used by the DevOps module to link pipelines and by the project
  /// detail page to link to the repo directly.
  githubRepo String?

  /// Overall project progress 0–100 (%) updated manually by the
  /// project manager or computed from completed milestones.
  progressPercent Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  User?           @relation("ProjectClient", fields: [clientId], references: [id], onDelete: SetNull)
  owner   User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members ProjectMember[]
  sprints Sprint[]
  boards  Board[]
  tasks   Task[]

  // Milestones for progress tracking visible to the client.
  milestones ProjectMilestone[]

  // Finance module back-references.
  financeTransactions FinanceTransaction[]
  costCenters         CostCenter[]
  invoices            Invoice[]

  // DevOps module back-references — one project can own many
  // environments and many pipelines.
  environments Environment[]
  pipelines    Pipeline[]

  // VPS bindings — a project can have one or more VPS attached.
  vpsBindings ClientVPS[]

  @@index([status])
  @@index([ownerId])
  @@index([clientId])
  @@map("projects")
}

/// Milestone or phase inside a project. Visible to the client as
/// a progress step. Completed milestones drive the
/// `progressPercent` calculation when auto-sync is enabled.
model ProjectMilestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  /// Milestone order (display order in the roadmap).
  order       Int       @default(0)
  /// When the milestone was marked complete. Null = pending.
  completedAt DateTime?
  dueDate     DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, order])
  @@map("project_milestones")
}

model ProjectMember {
  projectId String
  userId    String
  role      ProjectMemberRole @default(DEVELOPER)
  joinedAt  DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@index([role])
  @@map("project_members")
}

model Sprint {
  id        String       @id @default(cuid())
  projectId String
  name      String
  goal      String?
  startDate DateTime     @db.Date
  endDate   DateTime     @db.Date
  status    SprintStatus @default(PLANNED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  /// Composite — the "active sprint" lookup hits this directly.
  @@index([projectId, status])
  @@map("project_sprints")
}

model Board {
  id        String @id @default(cuid())
  projectId String
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns Column[]

  @@index([projectId])
  @@map("project_boards")
}

model Column {
  id       String @id @default(cuid())
  boardId  String
  name     String
  /// Display order within the board. Hot index for the board fetch
  /// (column ordering) — see `@@index([boardId, order])` below.
  order    Int    @default(0)
  /// Optional Work-In-Progress limit (number of tasks allowed in
  /// this column). The service enforces it on `move-to-column`;
  /// `null` means unlimited.
  wipLimit Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  /// Hot path — used by `GET /projects/:id/board` to fetch columns
  /// in display order in a single index range scan.
  @@index([boardId, order])
  @@map("project_columns")
}

model Task {
  id        String  @id @default(cuid())
  projectId String
  /// Optional sprint assignment. Tasks in the backlog have no sprint.
  sprintId  String?
  /// The current Kanban column. Required because every task lives
  /// on the board somewhere — the "backlog" is itself a column.
  columnId  String

  title       String
  description String?
  type        TaskType     @default(TASK)
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)

  /// Nullable for open work items (community-tagged tickets). When
  /// set, must be a member of the project (enforced by the service).
  assigneeId String?
  /// The reporter is required — every task has someone who created
  /// it. Restricted on delete so audit trails survive user removal.
  reporterId String

  /// Decimal (10, 2) is plenty — no real task tracks fractional
  /// minutes finer than 0.01h. Estimates are nullable because new
  /// tasks may not have a sizing yet.
  estimatedHours Decimal? @db.Decimal(10, 2)
  loggedHours    Decimal  @default(0) @db.Decimal(10, 2)

  /// Optional deadline. Different from the sprint endDate — a task
  /// can have its own due date inside a sprint or out of one.
  dueDate DateTime? @db.Date

  /// Display order within the task's column. The board fetch returns
  /// tasks sorted by `(columnId, order)`. Drag-and-drop reorders
  /// renumber within the affected columns inside one $transaction.
  order Int @default(0)

  /// Free-form tag list. Postgres `text[]` so labels stay queryable
  /// without a separate join table for the typical small cardinality.
  labels String[] @default([])

  /// Self-reference for subtasks. Cascade on delete so removing a
  /// parent epic also removes its children.
  parentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint      Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  column      Column      @relation(fields: [columnId], references: [id], onDelete: Restrict)
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter    User        @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  parent      Task?       @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]      @relation("TaskSubtasks")
  timeEntries TimeEntry[]

  /// HOTTEST INDEX — every board fetch and every drag-and-drop hits
  /// this composite. With it, "all tasks in column X ordered by
  /// position" is one index range scan.
  @@index([columnId, order])
  /// Used by the sprint board / burndown endpoint and by the
  /// per-status filters on the project view.
  @@index([projectId, status])
  /// Used by `GET /projects/:id/sprint/active` to pull the sprint's
  /// task list with one query.
  @@index([sprintId])
  /// "My open tasks" dashboard query.
  @@index([assigneeId, status])
  /// Subtask resolution — used when expanding an epic.
  @@index([parentId])
  @@map("project_tasks")
}

model TimeEntry {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  description String?
  hours       Decimal  @db.Decimal(10, 2)
  /// Date the work was performed (not the day it was logged).
  /// Drives the burndown rollup on the active-sprint endpoint.
  date        DateTime @db.Date

  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  /// Burndown rollup — `(taskId, date)` is the composite the sprint
  /// burndown query groups on, so the per-day sum is an index-only
  /// scan instead of a heap scan.
  @@index([taskId, date])
  @@index([userId, date])
  @@map("project_time_entries")
}

// =============================================================================
// Finance module — transactions, cost centers, invoices.
//
// Migration name: add_finance_module
//
// Design notes:
//   - `FinanceTransaction` (not `Transaction`) — `Transaction` is a
//     reserved word inside the generated Prisma client (collides
//     with `$transaction`), so the public model name is prefixed.
//     The table is still mapped to `finance_transactions`.
//   - Decimal(14, 2) everywhere so no real R$ amount ever overflows
//     and cents are always preserved. 14 digits cover R$ 999 bilhões.
//   - Every filterable column on FinanceTransaction has an index so
//     the DRE / cashflow groupBy hits the index instead of the heap.
//   - Composite `(status, dueDate)` index powers the daily OVERDUE
//     sweep — the BullMQ job filters by exactly those two columns
//     (`status = PENDING AND dueDate < now()`), so the composite
//     turns the sweep into an index range scan.
//   - Invoice.number is generated by the service (YYYY-0001), kept
//     unique so the finance UI can look an invoice up by number
//     alone and so accidental duplicates are impossible.
// =============================================================================

enum FinanceTransactionType {
  INCOME
  EXPENSE
}

enum FinanceTransactionCategory {
  SALARY
  SERVICE
  PRODUCT
  TAX
  INFRA
  MARKETING
  OTHER
}

enum FinanceTransactionStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

/// A single financial record — either income (customer payment,
/// invoice settlement) or expense (payroll, infrastructure cost,
/// tax). Drives the DRE and cash-flow reports.
///
/// `projectId` + `costCenterId` are both optional so one-off
/// transactions with no project attribution (e.g. company-wide
/// AWS bill) can still be recorded; the reports treat `null` as
/// "general overhead".
model FinanceTransaction {
  id            String                     @id @default(cuid())
  type          FinanceTransactionType
  category      FinanceTransactionCategory
  description   String
  /// The signed amount of the transaction. ALWAYS stored as a
  /// positive number — direction (income vs expense) is encoded
  /// in `type`, never via sign. This makes aggregations simple
  /// and avoids signed/unsigned bugs in the DRE query.
  amount        Decimal                    @db.Decimal(14, 2)
  /// Business date the transaction relates to (not when it was
  /// recorded). Drives the period filter on the DRE / cashflow.
  date          DateTime                   @db.Date
  status        FinanceTransactionStatus   @default(PENDING)
  /// When payment is due. Nullable because cash-basis transactions
  /// may not have a separate due date from `date`.
  dueDate       DateTime?                  @db.Date
  /// When payment was actually recorded. Set together with the
  /// PAID status transition.
  paidAt        DateTime?
  projectId     String?
  costCenterId  String?
  /// Opaque key into the `@szdevs/storage` adapter (R2/local)
  /// for the supporting document (receipt, invoice PDF).
  attachmentKey String?
  notes         String?
  createdBy     String
  /// Set when this transaction was auto-generated from an Invoice
  /// payment. Unique so only one transaction exists per invoice
  /// (prevents duplicates if the webhook fires twice).
  invoiceId     String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  creator    User        @relation("FinanceTransactionCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  /// DRE / cashflow hot path — groupBy(type, category, date) slices
  /// by each column independently, so single-column indexes on the
  /// discriminators keep those queries index-only.
  @@index([type])
  @@index([category])
  @@index([status])
  @@index([date])
  @@index([projectId])
  @@index([costCenterId])
  @@index([createdBy])
  /// Hottest index — the daily OVERDUE sweep filters by
  /// `status = PENDING AND dueDate < now()`. The composite turns
  /// that sweep into a single index range scan.
  @@index([status, dueDate])
  @@map("finance_transactions")
}

/// Named buckets that group transactions for management accounting.
/// A cost center can either be project-scoped (one per project) or
/// company-wide (projectId = null for shared overhead).
model CostCenter {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String?
  /// Optional monthly budget ceiling. The reports flag a cost
  /// center as "over budget" when the sum of its EXPENSE
  /// transactions for the period exceeds this value.
  budget      Decimal? @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  transactions FinanceTransaction[]

  @@index([projectId])
  @@index([name])
  @@map("finance_cost_centers")
}

/// Configurable installment interest conditions used in transparent checkout.
/// Each row represents one available installment option (e.g. "3× sem juros"
/// or "6× com 1.99% a.m."). The checkout UI picks the right condition based
/// on the chosen installment count.
model PaymentCondition {
  id           String  @id @default(cuid())
  name         String
  description  String?
  installments Int
  /// Monthly interest rate as a decimal fraction, e.g. 0.0199 = 1.99 % a.m.
  /// Zero means interest-free ("sem juros").
  interestRate Decimal @default(0) @db.Decimal(6, 4)
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([installments])
  @@index([active])
  @@map("finance_payment_conditions")
}

/// Customer-facing invoice — header row. Line items live in
/// `InvoiceItem`. `subtotal`, `tax`, and `total` are all stored
/// rather than recomputed on read so the PDF renderer and the
/// financial reports see the same frozen values even if the
/// underlying items are edited on a draft later.
model Invoice {
  id        String        @id @default(cuid())
  /// Human-friendly invoice number (e.g. "2026-0001"). Generated
  /// by the service on insert; unique across the whole table so
  /// lookups by number alone are possible.
  number    String        @unique
  clientId  String
  /// Optional project this invoice relates to. SetNull on project
  /// delete so the invoice history is never lost.
  projectId String?
  subtotal  Decimal       @db.Decimal(14, 2)
  tax       Decimal       @default(0) @db.Decimal(14, 2)
  total     Decimal       @db.Decimal(14, 2)
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime
  dueDate     DateTime      @db.Date
  paidAt      DateTime?
  cancelledAt DateTime?
  refundedAt  DateTime?
  cancelReason String?
  notes       String?
  createdBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   User          @relation("InvoiceClient", fields: [clientId], references: [id], onDelete: Restrict)
  creator  User          @relation("InvoiceCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  project  Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items    InvoiceItem[]
  payments Payment[]

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([issuedAt])
  @@index([dueDate])
  @@index([status, dueDate])
  @@map("finance_invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  /// Decimal (not Int) so fractional units (hours, kg) are
  /// representable without ad-hoc scaling.
  quantity    Decimal @db.Decimal(14, 3)
  unitPrice   Decimal @db.Decimal(14, 2)
  total       Decimal @db.Decimal(14, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("finance_invoice_items")
}

// =============================================================================
// Recurring Billing module — client billing subscriptions with
// automatic invoice generation.
//
// Migration name: add_recurring_billing
//
// Design notes:
//   - `BillingProduct` is a reusable catalog (products/services) used
//     to pre-populate subscription line items without manual entry.
//   - `RecurringSubscription` is a billing contract per client. It
//     drives the daily scheduler that generates invoices.
//   - When a subscription is CANCELLED, `endsAt` is set to the end of
//     the current billing period so the client keeps their benefits.
//   - `nextBillingDate` is a plain Date (no time) advanced by one month
//     each time an invoice is generated by the scheduler.
// =============================================================================

model BillingProduct {
  id          String   @id @default(cuid())
  name        String
  description String?
  /// Default unit price charged per unit.
  unitPrice   Decimal  @db.Decimal(14, 2)
  /// Unit label shown on the invoice line, e.g. "mês", "ano", "GB", "hora".
  unit        String   @default("mês")
  /// Free-form category tag for grouping, e.g. "VPS", "Hospedagem".
  category    String?
  isActive    Boolean  @default(true)
  /// When true, this product appears in /admin/developer/licencas for license management.
  isLicensed  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptionItems RecurringSubscriptionItem[]

  @@index([isActive])
  @@index([isLicensed])
  @@map("billing_products")
}

enum RecurringSubscriptionStatus {
  ACTIVE
  /// Cancelled but service continues until endsAt.
  CANCELLED
  /// Service period has ended.
  EXPIRED
  /// Suspended due to non-payment.
  SUSPENDED
}

model RecurringSubscription {
  id          String                      @id @default(cuid())
  clientId    String
  name        String
  description String?
  status      RecurringSubscriptionStatus @default(ACTIVE)
  /// Day of month (1–28) on which the recurring invoice is generated.
  billingDay     Int      @default(1)
  /// Number of days after the billing day before the invoice is due.
  billingDueDays Int      @default(5)
  /// Next date on which the scheduler will generate an invoice.
  nextBillingDate DateTime @db.Date
  cancelledAt     DateTime?
  cancelReason    String?
  /// Date through which the client retains access after cancellation.
  endsAt          DateTime?
  notes           String?  @db.Text
  createdBy       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  User @relation("RecurringSubClient", fields: [clientId], references: [id], onDelete: Restrict)
  creator User @relation("RecurringSubCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  items   RecurringSubscriptionItem[]

  @@index([clientId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("billing_recurring_subscriptions")
}

model RecurringSubscriptionItem {
  id             String  @id @default(cuid())
  subscriptionId String
  /// Optional link to the product catalog. Null = custom/manual line.
  productId      String?
  description    String
  quantity       Decimal @db.Decimal(14, 3) @default(1)
  unitPrice      Decimal @db.Decimal(14, 2)
  total          Decimal @db.Decimal(14, 2)

  subscription RecurringSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product      BillingProduct?       @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@map("billing_recurring_subscription_items")
}

// =============================================================================
// Notifications module — in-app notifications.
//
// Migration name: add_notifications
//
// Design notes:
//   - `type` is a free-form string (not an enum) because the set of
//     notification kinds evolves fast — the notification-service
//     adds new ones without requiring a schema migration each time.
//   - `read` is a denormalized boolean alongside `readAt` so the
//     unread-count query is a simple index range scan instead of
//     a `WHERE readAt IS NULL` on a nullable column.
//   - `(userId, read)` composite index is the hot path: the inbox
//     UI fetches `user's unread notifications` on every page load.
//   - `(userId, createdAt)` is the secondary path for paginated
//     history. Both indexes are cheap on a write-light table.
// =============================================================================

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  /// Free-form type key, e.g. "vacation.approved", "payment.due",
  /// "contact.confirmation". Frontends branch on this to pick an
  /// icon and a click-through destination.
  type      String
  read      Boolean   @default(false)
  readAt    DateTime?
  /// Optional deep-link URL the frontend navigates to when the
  /// notification is clicked. Null for purely informational items.
  link      String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Hottest index — the inbox fetch filters by userId and the
  /// unread flag in one composite range scan.
  @@index([userId, read])
  /// Secondary — paginated history by recency for the full inbox.
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}

// =============================================================================
// Support module — tickets, messages, attachments, SLA.
//
// Migration name: add_support_module
//
// Design notes:
//   - `Ticket.number` is an auto-incrementing Int separate from the
//     cuid primary key so humans can reference "#1042" instead of a
//     25-char opaque id. A Postgres sequence backs it; uniqueness is
//     enforced at the DB level.
//   - `status` has no `CANCELLED` value — closed tickets move to
//     CLOSED after RESOLVED, which makes SLA reporting simpler
//     (RESOLVED means SLA fulfilled; CLOSED means the conversation
//     is over and includes abandoned/duplicate cases).
//   - `firstResponseAt` is set once (by the first non-client message),
//     never overwritten. Drives the first-response-SLA metric.
//   - `resolvedAt` is set when the status flips to RESOLVED. Drives
//     the resolution-SLA metric. Re-opening a ticket does NOT clear
//     resolvedAt — we keep the original for reporting and instead
//     stamp a new resolvedAt only if the agent re-resolves.
//   - Hot indexes: (status), (assigneeId, status), (clientId, status)
//     so the three main inbox queries are all index-only scans.
// =============================================================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  BUG
  FEATURE
  QUESTION
  BILLING
  OTHER
}

model Ticket {
  id              String         @id @default(cuid())
  /// Auto-incrementing human-friendly number. Uses a Postgres
  /// sequence via @default(autoincrement()); the migration creates
  /// the sequence explicitly.
  number          Int            @unique @default(autoincrement())
  title           String
  description     String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  category        TicketCategory @default(QUESTION)
  /// Null for public contact-form tickets (unauthenticated visitors).
  clientId        String?
  /// Optional because a fresh ticket lives in OPEN with no assignee
  /// until someone in support picks it up (or the triage bot assigns
  /// it based on category).
  assigneeId      String?
  /// Computed at creation time from the matching SLAPolicy plus the
  /// business-hours calendar. Stored rather than recomputed on read
  /// so SLA reports are consistent with what the client saw when
  /// their ticket was opened.
  slaDeadline     DateTime?
  /// First time a non-client user sent a message on this ticket.
  /// Null until the first agent reply lands. Never re-opened.
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  /// CSAT rating 1-5, captured after the client clicks the rating
  /// link in the closure email. Null while the ticket is still open.
  rating          Int?
  ratingComment   String?
  /// Free-form tag list. Small cardinality per ticket (usually
  /// 0-3), so Postgres text[] is cheaper than a join table.
  tags            String[]       @default([])
  /// Visitor info for public contact-form tickets (clientId = null).
  guestName       String?
  guestEmail      String?
  guestPhone      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client      User?              @relation("TicketClient", fields: [clientId], references: [id], onDelete: SetNull)
  assignee    User?              @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages    TicketMessage[]
  attachments TicketAttachment[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([clientId, status])
  @@index([assigneeId, status])
  @@index([slaDeadline])
  @@index([createdAt])
  @@map("support_tickets")
}

model TicketMessage {
  id         String  @id @default(cuid())
  ticketId   String
  authorId   String
  body       String
  /// Internal note — visible only to support staff, never to the
  /// client. Enforced in the service layer, not at the DB.
  isInternal Boolean @default(false)

  createdAt DateTime @default(now())

  ticket      Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User               @relation("TicketMessageAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  attachments TicketAttachment[]

  @@index([ticketId, createdAt])
  @@index([authorId])
  @@map("support_ticket_messages")
}

model TicketAttachment {
  id         String   @id @default(cuid())
  ticketId   String
  /// Nullable because an attachment can be attached to the ticket
  /// itself (e.g. the initial payload) without belonging to any
  /// single message yet.
  messageId  String?
  /// Opaque key into the `@szdevs/storage` adapter.
  fileKey    String
  filename   String
  size       Int
  mimeType   String
  /// When true, only support agents (support:tickets:close) can see this file.
  isPrivate  Boolean  @default(false)
  uploadedAt DateTime @default(now())

  ticket  Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message TicketMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([messageId])
  @@map("support_ticket_attachments")
}

/// SLA policy — one active row per priority level. The service
/// reads the row for the ticket's priority at creation time and
/// computes `slaDeadline` from it. `isActive` lets ops toggle a
/// policy on/off without deleting history.
model SLAPolicy {
  id                 String         @id @default(cuid())
  priority           TicketPriority @unique
  /// How many business hours after ticket creation the first agent
  /// response must land.
  firstResponseHours Int
  /// How many business hours after ticket creation the ticket
  /// must be RESOLVED.
  resolutionHours    Int
  isActive           Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_sla_policies")
}

// =============================================================================
// DevOps module — environments, pipelines, deployments.
//
// Migration name: add_devops_module
//
// Design notes:
//   - `Environment.status` is the CURRENT health cached from the
//     last health-check run. Historical samples live in a
//     separate `EnvironmentHealthCheck` table so the history
//     query never joins the main row.
//   - `Pipeline.externalId` is the GitHub/GitLab run-id (string,
//     not int, because providers differ). `(provider, externalId)`
//     is unique so the webhook handler can upsert by id idempotently
//     even if the same webhook fires twice.
//   - `Pipeline.status` uses DB-managed enum with all four states.
//     `duration` is stored on the row (precomputed when finishedAt
//     lands) instead of recomputed on read — the list query stays
//     index-only.
//   - Hot indexes: `(projectId, status)` for the board,
//     `(status)` for the "all running pipelines" filter,
//     `(externalId, provider)` unique composite for webhook upserts.
//   - `PipelineLog` has `(pipelineId, startedAt)` composite to
//     fetch the log stream in chronological order without a sort.
// =============================================================================

enum EnvironmentType {
  PRODUCTION
  STAGING
  DEVELOPMENT
}

enum EnvironmentStatus {
  HEALTHY
  DEGRADED
  DOWN
  UNKNOWN
}

enum PipelineProvider {
  GITHUB_ACTIONS
  GITLAB_CI
}

enum PipelineStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum PipelineLogStatus {
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum DeploymentStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  ROLLED_BACK
}

model Environment {
  id          String            @id @default(cuid())
  name        String
  type        EnvironmentType
  projectId   String
  /// Public URL the health-check job pings every 5 minutes.
  /// Stored as TEXT so query strings and path suffixes are fine.
  url         String
  status      EnvironmentStatus @default(UNKNOWN)
  /// When the status field was last refreshed by the health
  /// check. Null while the environment hasn't been probed yet.
  lastCheckAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]
  history     EnvironmentHealthCheck[]

  @@index([projectId])
  @@index([status])
  @@map("devops_environments")
}

/// Time-series row appended by the health-check job on every
/// probe. The (environmentId, checkedAt) index powers the history
/// endpoint's date-range query.
model EnvironmentHealthCheck {
  id             String            @id @default(cuid())
  environmentId  String
  status         EnvironmentStatus
  /// HTTP status code the probe received. Null when the request
  /// failed before a response (DNS, TCP, TLS, timeout).
  httpStatus     Int?
  /// Round-trip time in milliseconds. Null on failed probes.
  responseTimeMs Int?
  /// Free-form error string when the probe failed. Limited to
  /// 500 chars so misbehaving upstreams can't bloat the table.
  error          String?
  checkedAt      DateTime          @default(now())

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([environmentId, checkedAt])
  @@map("devops_environment_health_checks")
}

model Pipeline {
  id            String           @id @default(cuid())
  name          String
  projectId     String
  provider      PipelineProvider
  /// CI/CD provider's own run id. Used to upsert from webhooks
  /// and to call the provider's REST API for a live re-fetch.
  externalId    String
  branch        String
  status        PipelineStatus   @default(QUEUED)
  startedAt     DateTime?
  finishedAt    DateTime?
  triggeredBy   String?
  commitSha     String
  commitMessage String?
  /// Total duration in seconds, computed when finishedAt lands
  /// so the list view doesn't recompute it per row.
  duration      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logs        PipelineLog[]
  deployments Deployment[]

  /// Webhook idempotency — the webhook handler upserts on this
  /// composite so the same delivery never creates two rows.
  @@unique([provider, externalId])
  @@index([projectId, status])
  @@index([status])
  @@index([branch])
  @@index([startedAt])
  @@map("devops_pipelines")
}

model PipelineLog {
  id         String            @id @default(cuid())
  pipelineId String
  /// Human-readable step name (usually the job/step name from
  /// the provider — "install", "test", "deploy").
  step       String
  /// Raw output from the step. TEXT so huge logs don't overflow.
  /// The service caps per-row at 1MB when persisting via webhook.
  output     String
  status     PipelineLogStatus
  startedAt  DateTime
  finishedAt DateTime?

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId, startedAt])
  @@map("devops_pipeline_logs")
}

model Deployment {
  id            String           @id @default(cuid())
  pipelineId    String
  environmentId String
  status        DeploymentStatus @default(PENDING)
  deployedAt    DateTime         @default(now())
  rolledBackAt  DateTime?
  /// The user who triggered the deployment. Restricted on delete
  /// so the audit trail survives — admins must reassign before
  /// removing a user who has deployments on record.
  deployedBy    String

  pipeline    Pipeline    @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Restrict)
  user        User        @relation("DeploymentDeployedBy", fields: [deployedBy], references: [id], onDelete: Restrict)

  @@index([pipelineId])
  @@index([environmentId, deployedAt])
  @@index([status])
  @@index([deployedBy])
  @@map("devops_deployments")
}

// =============================================================================
// Payments module — plans, subscriptions, payments, coupons.
//
// Migration name: add_payments_module
//
// Design notes:
//   - `Subscription.externalId` is the Mercado Pago subscription
//     ID (preapproval_id). The webhook handler upserts by this
//     field so re-deliveries never create duplicates.
//   - `Payment.externalId` is the MP payment_id. Same upsert
//     strategy. `externalUrl` stores the MP init_point for PIX
//     QR / boleto link so the frontend can redirect directly.
//   - `Payment.metadata` is a Json column for provider-specific
//     fields (pix_qr_code, barcode, card_last_four, etc.) that
//     don't warrant their own typed columns.
//   - `Coupon.code` is case-insensitive unique. The service
//     lowercases on insert and lookup so "WELCOME" and "welcome"
//     resolve to the same row.
//   - Hot indexes: (userId, status) on Subscription, (userId)
//     on Payment, (subscriptionId) on Payment.
// =============================================================================

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  EXPIRED
}

enum PaymentMethod {
  PIX
  BOLETO
  CREDIT_CARD
  DEBIT_CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

model Plan {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Decimal      @db.Decimal(14, 2)
  interval    PlanInterval
  /// Feature list displayed on the pricing page. Postgres
  /// text[] for small cardinality without a join table.
  features    String[]     @default([])
  /// Free trial length in days. 0 means no trial.
  trialDays   Int          @default(0)
  isActive    Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive])
  @@map("payments_plans")
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  /// Provider subscription id (MP preapproval_id / Stripe sub_xxx).
  externalId         String?            @unique
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  /// Trial end — null when the plan has trialDays=0.
  trialEnd           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan     Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@index([userId, status])
  @@index([externalId])
  @@index([status])
  @@map("payments_subscriptions")
}

model Payment {
  id             String        @id @default(cuid())
  subscriptionId String?
  /// Optional — links this payment to a specific Finance invoice.
  invoiceId      String?
  userId         String
  amount         Decimal       @db.Decimal(14, 2)
  currency       String        @default("BRL")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  /// Provider payment id (MP payment_id / Stripe pi_xxx).
  externalId     String?       @unique
  /// Checkout URL — the MP init_point or Stripe checkout
  /// session URL the frontend redirects to.
  externalUrl    String?
  paidAt         DateTime?
  expiresAt      DateTime?
  /// Freeform provider-specific data — pix QR code, boleto
  /// barcode, card last 4 digits, etc.
  metadata       Json          @default("{}")

  createdAt DateTime @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([subscriptionId])
  @@index([invoiceId])
  @@index([userId])
  @@index([externalId])
  @@index([status])
  @@map("payments_payments")
}

model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  discount  Decimal    @db.Decimal(14, 2)
  type      CouponType
  maxUses   Int        @default(0)
  usedCount Int        @default(0)
  expiresAt DateTime?
  isActive  Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("payments_coupons")
}

// ──────────────────────────────────────────────
// License Module
// ──────────────────────────────────────────────

enum TokenStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model LicensedProduct {
  id          String  @id @default(cuid())
  name        String
  description String?
  /// Unique application identifier used by client SDKs during verification.
  appId       String  @unique

  createdAt DateTime @default(now())

  bindings         ClientProductBinding[]
  activationTokens ActivationToken[]

  @@map("license_products")
}

model ClientProductBinding {
  id         String    @id @default(cuid())
  clientId   String
  productId  String
  assignedBy String
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?

  client  User            @relation("LicenseClient", fields: [clientId], references: [id], onDelete: Restrict)
  product LicensedProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  granter User            @relation("LicenseAssignedBy", fields: [assignedBy], references: [id], onDelete: Restrict)

  @@unique([clientId, productId])
  @@index([clientId])
  @@index([productId])
  @@map("license_client_bindings")
}

model ActivationToken {
  id           String      @id @default(cuid())
  /// UUID v4 activation key delivered to the client.
  key          String      @unique
  /// SHA-256 hex digest of `key` — enables offline verification
  /// without exposing the raw key in the database.
  hash         String
  clientId     String
  productId    String
  maxUses      Int?
  usedCount    Int         @default(0)
  expiresAt    DateTime?
  /// If set, the token is bound to this specific hardware fingerprint.
  hardwareId   String?
  status       TokenStatus @default(ACTIVE)
  issuedBy     String
  issuedAt     DateTime    @default(now())
  revokedBy    String?
  revokedAt    DateTime?
  revokeReason String?

  client  User            @relation("TokenClient", fields: [clientId], references: [id], onDelete: Restrict)
  product LicensedProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  issuer  User            @relation("TokenIssuedBy", fields: [issuedBy], references: [id], onDelete: Restrict)
  revoker User?           @relation("TokenRevokedBy", fields: [revokedBy], references: [id], onDelete: SetNull)

  activations TokenActivation[]

  @@index([clientId])
  @@index([productId])
  @@index([status])
  @@index([hash])
  @@map("license_activation_tokens")
}

model TokenActivation {
  id          String   @id @default(cuid())
  tokenId     String
  hardwareId  String?
  appVersion  String?
  ipAddress   String?
  activatedAt DateTime @default(now())

  token ActivationToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId])
  @@map("license_token_activations")
}

// =============================================================================
// VPS management module — links Hostinger VMs to internal clients.
//
// Migration name: add_vps_management
//
// Design notes:
//   - `vmId` is the opaque ID returned by the Hostinger API; we keep it
//     as the join key against the upstream provider. The unique
//     constraint prevents the same VM from being attached to two
//     different clients by accident.
//   - `clientId` is restricted on delete so we don't lose the link to
//     a billing client by mistake. Detaching the VPS is an explicit
//     operation (POST /vps/<id>/detach in the controller).
//   - `notes` is internal-only — used by ops to remember things like
//     "renew SSL on 2026-12", not exposed to clients.
//   - All actuator actions (start/stop/restart/snapshot) audit through
//     AuditLog with module = DEVELOPER and action = VPS_*.
// =============================================================================

model ClientVPS {
  id         String   @id @default(cuid())
  clientId   String
  /// Optional project this VPS belongs to.
  projectId  String?
  vmId       String
  label      String
  hostname   String
  plan       String
  dataCenter String
  ipv4       String
  notes      String?  @db.Text
  addedAt    DateTime @default(now())
  addedBy    String

  /// Monthly billing price in BRL. Null = unmanaged (no auto-billing).
  monthlyPrice         Decimal?  @db.Decimal(14, 2)
  /// Day-of-month (1–28) the recurring invoice is generated.
  billingDayOfMonth    Int       @default(1)
  /// When the last auto-invoice was created for this VPS.
  lastBilledAt         DateTime?
  /// Days after invoice due-date before the VPS is suspended.
  suspendAfterDays     Int       @default(3)
  /// When the VPS was automatically suspended due to non-payment.
  suspendedAt          DateTime?

  client      User     @relation("ClientVPSClient", fields: [clientId], references: [id], onDelete: Restrict)
  addedByUser User     @relation("ClientVPSAttachedBy", fields: [addedBy], references: [id], onDelete: Restrict)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([vmId])
  @@index([clientId])
  @@index([projectId])
  @@index([addedAt])
  @@map("client_vps")
}

// =============================================================================
// API Keys module — public API gateway key management.
//
// Migration name: add_api_keys_module
//
// Design notes:
//   - The full secret is shown exactly once at creation time and never stored
//     in plaintext. Only the bcrypt hash (keyHash) is persisted so a DB dump
//     doesn't expose live keys.
//   - keyPrefix stores "szd_live_XXXXXXXX" for O(1) lookup before bcrypt compare.
//   - Permissions are a plain string array (e.g. ["tickets:read","projects:write"]).
//   - IP binding supports three modes: DISABLED (skip), AUTO (learn first IP),
//     MANUAL (explicit allowlist in boundIps).
//   - rateLimit is a JSON object { perMinute, perHour, perDay } storing the limits.
//   - ApiKeyAuditLog captures every REQUEST_OK, BLOCKED_IP, RATE_LIMITED event.
// =============================================================================

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  SUSPENDED
  EXPIRED
}

enum IpBindingMode {
  DISABLED
  AUTO
  MANUAL
}

model ApiKey {
  id          String        @id @default(cuid())
  name        String
  /// First segment of the key: "szd_live_XXXXXXXX". Used for O(1) DB lookup.
  keyPrefix   String        @unique
  /// bcrypt hash of the 32-char secret. Never stored in plaintext.
  keyHash     String
  status      ApiKeyStatus  @default(ACTIVE)
  /// String array of permission scopes, e.g. ["tickets:read","projects:write"].
  permissions String[]
  ipBinding   IpBindingMode @default(DISABLED)
  /// IP addresses allowed when ipBinding = MANUAL, or the auto-learned IP
  /// when ipBinding = AUTO. Empty when DISABLED or before first AUTO use.
  boundIps    String[]
  /// Rate-limit config stored as JSON: { perMinute: Int, perHour: Int, perDay: Int }
  rateLimit   Json
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  lastUsedIp  String?
  totalRequests Int         @default(0)
  revokeReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs ApiKeyAuditLog[]

  @@index([status])
  @@index([createdAt])
  @@map("api_keys")
}

model ApiKeyAuditLog {
  id       String @id @default(cuid())
  apiKeyId String
  /// Event type: REQUEST_OK | BLOCKED_IP | RATE_LIMITED | KEY_CREATED | KEY_REVOKED
  event    String
  ip       String?
  endpoint String?
  /// HTTP status code for REQUEST_OK events.
  statusCode Int?
  meta     Json     @default("{}")
  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([event])
  @@index([createdAt])
  @@map("api_key_audit_logs")
}

// =============================================================================
// Company Settings — legal data shown on invoices, pages and documents.
//
// Migration name: add_company_settings
//
// Design notes:
//   - Singleton table: only one row is ever expected (the owning company).
//     The `singleton` column is a unique boolean constraint that enforces this.
//   - `logoKey` is an opaque @szdevs/storage key, just like employee docs.
//   - Brazilian legal fields (CNPJ, IE, IM) are stored as plain strings so
//     we can accommodate future formatting changes without a migration.
// =============================================================================

model CompanySettings {
  id                String  @id @default(cuid())
  /// Singleton guard — this row is always `true`; unique prevents a second insert.
  singleton         Boolean @unique @default(true)

  name              String
  tradeName         String?
  /// CNPJ in digits-only format (14 chars). Formatted for display by the UI.
  cnpj              String?
  /// Inscrição Estadual
  stateRegistration String?
  /// Inscrição Municipal
  municipalRegistration String?

  email             String?
  phone             String?
  website           String?

  /// Full address for invoices / billing
  addressStreet     String?
  addressNumber     String?
  addressComplement String?
  addressNeighborhood String?
  addressCity       String?
  addressState      String?
  /// Brazilian CEP — 8 digits
  addressZip        String?

  /// Payment address if different from operational address
  paymentAddressStreet      String?
  paymentAddressNumber      String?
  paymentAddressComplement  String?
  paymentAddressNeighborhood String?
  paymentAddressCity        String?
  paymentAddressState       String?
  paymentAddressZip         String?

  /// Opaque storage key for the company logo. Null = not uploaded.
  logoKey           String?

  /// Free-form footer text for invoices (e.g. bank details, PIX key)
  invoiceFooter     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_settings")
}
