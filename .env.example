# =============================================================================
# SZDevs - Environment variables (example)
# Copy this file to `.env` at the repository root and fill in real values.
# The file is consumed by docker-compose (infra/docker-compose.yml) and by
# each Next.js / NestJS workspace.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL (shared by all NestJS services)
# -----------------------------------------------------------------------------
POSTGRES_USER=SZDevs
POSTGRES_PASSWORD=SZDevs
POSTGRES_DB=SZDevs
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full connection string used by the services
DATABASE_URL=postgresql://SZDevs:SZDevs@postgres:5432/SZDevs

# -----------------------------------------------------------------------------
# Redis (cache, queues, pub/sub)
# REDIS_PASSWORD must be set — Redis requires authentication (SZD-648).
# Dev workflow (native host): REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
# Docker/prod:               REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# -----------------------------------------------------------------------------
# Authentication / JWT (auth-service)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=30d
# Optional: separate secret for 2FA temp tokens (falls back to JWT_SECRET if unset)
JWT_2FA_TEMP_SECRET=change-me-to-a-2fa-temp-secret
# Shared secret for internal service-to-service calls (OAuth peer login, etc.)
AUTH_INTERNAL_SECRET=change-me-to-a-strong-internal-secret
# Allowed CORS origins for the auth-service (comma-separated)
CORS_ORIGINS=https://szdevs.com,http://localhost:4000

# -----------------------------------------------------------------------------
# NestJS microservices - internal ports
# (each service listens on its own port inside the `SZDevs` network)
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=3001
RH_SERVICE_PORT=3002
FINANCE_SERVICE_PORT=3003
PROJECTS_SERVICE_PORT=3004
DEVOPS_SERVICE_PORT=3005
SUPPORT_SERVICE_PORT=3006
PAYMENTS_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
LICENSE_SERVICE_PORT=3009
DEVELOPER_SERVICE_PORT=3010

# Internal URLs (service-to-service calls, via docker network DNS)
AUTH_SERVICE_URL=http://auth-service:3001
RH_SERVICE_URL=http://rh-service:3002
FINANCE_SERVICE_URL=http://finance-service:3003
PROJECTS_SERVICE_URL=http://projects-service:3004
DEVOPS_SERVICE_URL=http://devops-service:3005
SUPPORT_SERVICE_URL=http://support-service:3006
PAYMENTS_SERVICE_URL=http://payments-service:3007
NOTIFICATION_SERVICE_URL=http://notification-service:3008
LICENSE_SERVICE_URL=http://license-service:3009
DEVELOPER_SERVICE_URL=http://developer-service:3010

# -----------------------------------------------------------------------------
# Next.js frontends - ports and public URLs
# -----------------------------------------------------------------------------
WEB_APP_PORT=4000
RH_APP_PORT=4001
FINANCEIRO_APP_PORT=4002
PROJETOS_APP_PORT=4003
DEVOPS_APP_PORT=4004
SUPORTE_APP_PORT=4005
STORE_APP_PORT=4006
DEVELOPER_APP_PORT=4007

# Public URLs exposed by nginx (what the browser hits)
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_WEB_URL=http://localhost
NEXT_PUBLIC_RH_URL=http://localhost/rh
NEXT_PUBLIC_FINANCEIRO_URL=http://localhost/financeiro
NEXT_PUBLIC_PROJETOS_URL=http://localhost/projetos
NEXT_PUBLIC_DEVOPS_URL=http://localhost/devops
NEXT_PUBLIC_SUPORTE_URL=http://localhost/suporte
NEXT_PUBLIC_STORE_URL=http://localhost/store
NEXT_PUBLIC_DEVELOPER_URL=http://localhost/developer

# -----------------------------------------------------------------------------
# Payments (payments-service -> Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# -----------------------------------------------------------------------------
# Notifications (notification-service -> SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@SZDevs.local
SMTP_PASS=change-me
SMTP_FROM="SZDevs <no-reply@SZDevs.local>"

# -----------------------------------------------------------------------------
# License (license-service + @szdevs/license-sdk)
# -----------------------------------------------------------------------------
LICENSE_SIGNING_KEY=replace-with-ed25519-private-key
LICENSE_PUBLIC_KEY=replace-with-ed25519-public-key

# -----------------------------------------------------------------------------
# Object storage (optional - S3 compatible, e.g. MinIO)
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=SZDevs

# -----------------------------------------------------------------------------
# Hostinger VPS API (developer-service /vps/*)
# -----------------------------------------------------------------------------
# Bearer token from https://hpanel.hostinger.com â†’ API. Required for the
# `dev:vps:manage` routes â€” leave blank to keep them returning 503.
HOSTINGER_API_TOKEN=
# Base URL â€” only override for staging/proxy. Default is the public API.
HOSTINGER_API_URL=https://developers.hostinger.com/api/vps/v1

# -----------------------------------------------------------------------------
# szdevs-api (subscription / AI balance service — runs on host via PM2)
# Production: http://172.16.1.1:5100 (Docker bridge gateway → host)
# Local dev:  http://localhost:5100
# -----------------------------------------------------------------------------
SZDEVS_API_URL=http://localhost:5100

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
