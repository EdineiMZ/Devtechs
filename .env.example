# =============================================================================
# SZDevs — Variáveis de ambiente (template)
# =============================================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores marcados com SUBSTITUA_*
# 3. NÃO commite o .env com segredos reais — ele está no .gitignore
#
# Para gerar strings aleatórias seguras (Linux/Mac):
#   openssl rand -base64 48 | tr -d '/+=' | cut -c1-64
#
# Para gerar via PowerShell (Windows):
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL — compartilhado por todos os serviços NestJS
# -----------------------------------------------------------------------------
POSTGRES_USER=szdevs
POSTGRES_PASSWORD=SUBSTITUA_SENHA_FORTE
POSTGRES_DB=szdevs
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL completa usada pelo Prisma / serviços
# Em dev local (sem Docker): postgresql://szdevs:senha@localhost:5432/szdevs
# Em Docker (padrão):        postgresql://szdevs:senha@postgres:5432/szdevs
DATABASE_URL=postgresql://szdevs:SUBSTITUA_SENHA_FORTE@postgres:5432/szdevs

# -----------------------------------------------------------------------------
# Redis — cache, filas, pub/sub
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# Em dev local (sem Docker): redis://localhost:6379
# Em Docker (padrão):        redis://redis:6379
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# JWT — auth-service
# -----------------------------------------------------------------------------
# Gere com: openssl rand -base64 48 | tr -d '/+=' | cut -c1-64
JWT_SECRET=SUBSTITUA_STRING_ALEATORIA_64_CHARS
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=SUBSTITUA_OUTRA_STRING_ALEATORIA_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d
JWT_2FA_TEMP_SECRET=SUBSTITUA_STRING_2FA_32_CHARS

# -----------------------------------------------------------------------------
# Criptografia — segredos 2FA e dados sensíveis
# CRÍTICO: Esta chave DEVE ser idêntica no .env raiz e em infra/.env
# Uma chave diferente causa falha silenciosa no 2FA
# Gere com: openssl rand -base64 24 | tr -d '/+=' | cut -c1-32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=SUBSTITUA_STRING_AES_32_CHARS_EXATA

# -----------------------------------------------------------------------------
# Auth interno — comunicação entre microserviços (bearer token)
# Gere com: openssl rand -base64 36 | tr -d '/+=' | cut -c1-48
# -----------------------------------------------------------------------------
AUTH_INTERNAL_SECRET=SUBSTITUA_STRING_INTERNA_48_CHARS

# -----------------------------------------------------------------------------
# Next.js / NextAuth
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:4000
# Gere com: openssl rand -base64 36 | tr -d '/+=' | cut -c1-48
NEXTAUTH_SECRET=SUBSTITUA_NEXTAUTH_SECRET_48_CHARS

# OAuth — GitHub
# Crie em: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:4000/api/auth/callback/github
GITHUB_CLIENT_ID=SUBSTITUA_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=SUBSTITUA_GITHUB_CLIENT_SECRET

# OAuth — Google
# Crie em: https://console.cloud.google.com → APIs → Credentials
# Callback URL: http://localhost:4000/api/auth/callback/google
GOOGLE_CLIENT_ID=SUBSTITUA_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=SUBSTITUA_GOOGLE_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Portas internas dos microserviços NestJS
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=3001
RH_SERVICE_PORT=3002
FINANCE_SERVICE_PORT=3003
PROJECTS_SERVICE_PORT=3004
DEVOPS_SERVICE_PORT=3005
SUPPORT_SERVICE_PORT=3006
PAYMENTS_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
LICENSE_SERVICE_PORT=3009
DEVELOPER_SERVICE_PORT=3010
API_SERVICE_PORT=3011

# URLs internas (service-to-service via DNS Docker)
# Em dev local, substitua "nome-servico" por "localhost"
AUTH_SERVICE_URL=http://auth-service:3001
RH_SERVICE_URL=http://rh-service:3002
FINANCE_SERVICE_URL=http://finance-service:3003
PROJECTS_SERVICE_URL=http://projects-service:3004
DEVOPS_SERVICE_URL=http://devops-service:3005
SUPPORT_SERVICE_URL=http://support-service:3006
PAYMENTS_SERVICE_URL=http://payments-service:3007
NOTIFICATION_SERVICE_URL=http://notification-service:3008
LICENSE_SERVICE_URL=http://license-service:3009
DEVELOPER_SERVICE_URL=http://developer-service:3010
API_SERVICE_URL=http://api-service:3011

# -----------------------------------------------------------------------------
# Portas dos apps Next.js
# -----------------------------------------------------------------------------
WEB_APP_PORT=4000
STORE_APP_PORT=4006

# -----------------------------------------------------------------------------
# URLs públicas — o que o browser enxerga
# Em produção: troque localhost pelo seu domínio (ex: https://szdevs.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WEB_URL=http://localhost:4000
NEXT_PUBLIC_STORE_URL=http://localhost:4006

# URLs das APIs (via nginx em prod, direto em dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3001
NEXT_PUBLIC_RH_SERVICE_URL=http://localhost:3002
NEXT_PUBLIC_FINANCE_URL=http://localhost:3003
NEXT_PUBLIC_PROJECTS_SERVICE_URL=http://localhost:3004
NEXT_PUBLIC_DEVOPS_SERVICE_URL=http://localhost:3005
NEXT_PUBLIC_SUPPORT_URL=http://localhost:3006
NEXT_PUBLIC_NOTIFICATION_URL=http://localhost:3008
NEXT_PUBLIC_LICENSE_URL=http://localhost:3009
NEXT_PUBLIC_DEVELOPER_URL=http://localhost:3010

# Legados (mantidos para compatibilidade)
NEXT_PUBLIC_RH_URL=http://localhost:3002
NEXT_PUBLIC_FINANCEIRO_URL=http://localhost:3003
NEXT_PUBLIC_PROJETOS_URL=http://localhost:3004
NEXT_PUBLIC_DEVOPS_URL=http://localhost:3005
NEXT_PUBLIC_SUPORTE_URL=http://localhost:3006
NEXT_PUBLIC_DEVELOPER_URL=http://localhost:3010

# -----------------------------------------------------------------------------
# CORS — origens permitidas nos serviços NestJS
# Em dev: http://localhost:4000,http://localhost:4006
# Em prod: https://szdevs.com,https://loja.szdevs.com
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:4000,http://localhost:4006

# -----------------------------------------------------------------------------
# E-mail (notification-service)
# Opção A — SMTP genérico
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=SUBSTITUA_SMTP_SENHA
SMTP_FROM="SZDevs <no-reply@example.com>"

# Opção B — Resend (https://resend.com — recomendado para produção)
# Se RESEND_API_KEY estiver preenchida, o serviço usa Resend em vez de SMTP
RESEND_API_KEY=
RESEND_FROM=SZDevs <no-reply@example.com>

# Para testes locais de e-mail, use Mailhog:
#   docker compose --profile dev-tools up -d
#   SMTP_HOST=localhost  SMTP_PORT=1025
#   Interface:           http://localhost:8025

# -----------------------------------------------------------------------------
# Pagamentos — Stripe (payments-service)
# Crie em: https://dashboard.stripe.com/apikeys
# Para webhooks locais: stripe listen --forward-to localhost:3007/webhooks/stripe
# -----------------------------------------------------------------------------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_SUBSTITUA
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUA
STRIPE_PUBLISHABLE_KEY=pk_test_SUBSTITUA
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_SUBSTITUA

# Mercado Pago (alternativo ao Stripe, para Brasil)
# Crie em: https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
NEXT_PUBLIC_MP_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Licenças — license-service + @szdevs/license-sdk
# Gere par Ed25519 com:
#   node -e "const c=require('crypto');const{privateKey,publicKey}=c.generateKeyPairSync('ed25519');console.log(privateKey.export({type:'pkcs8',format:'pem'}));console.log(publicKey.export({type:'spki',format:'pem'}))"
# -----------------------------------------------------------------------------
LICENSE_SIGNING_KEY=SUBSTITUA_ED25519_PRIVATE_KEY_PEM
LICENSE_PUBLIC_KEY=SUBSTITUA_ED25519_PUBLIC_KEY_PEM

# -----------------------------------------------------------------------------
# Object Storage — S3 compatível (packages/storage)
# Cloudflare R2, MinIO, AWS S3, etc.
#
# Para desenvolvimento local com MinIO:
#   docker compose --profile dev-tools up -d
#   STORAGE_ENDPOINT=http://localhost:9000
#   STORAGE_ACCESS_KEY=minioadmin
#   STORAGE_SECRET_KEY=minioadmin
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=szdevs

# -----------------------------------------------------------------------------
# Hostinger VPS API (developer-service — rotas /vps/*)
# Token em: https://hpanel.hostinger.com → API
# Deixe em branco para desativar (retorna 503 nas rotas VPS)
# -----------------------------------------------------------------------------
HOSTINGER_API_TOKEN=
HOSTINGER_API_URL=https://developers.hostinger.com/api/vps/v1

# -----------------------------------------------------------------------------
# Observabilidade (opcional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
