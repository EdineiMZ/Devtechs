# ---------------------------------------------------------------
# DevTechs - Example environment variables
# Copy this file to .env and fill in real values
# ---------------------------------------------------------------

# Node
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://devtechs:devtechs@localhost:5432/devtechs

# Redis
REDIS_URL=redis://localhost:6379

# Auth / JWT
JWT_SECRET=replace-me-with-a-strong-secret
JWT_EXPIRES_IN=1d

# Storage (S3 compatible)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=devtechs

# Public URLs - Frontends (Next.js)
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_RH_URL=http://localhost:3001
NEXT_PUBLIC_FINANCEIRO_URL=http://localhost:3002
NEXT_PUBLIC_PROJETOS_URL=http://localhost:3003
NEXT_PUBLIC_DEVOPS_URL=http://localhost:3004
NEXT_PUBLIC_SUPORTE_URL=http://localhost:3005
NEXT_PUBLIC_STORE_URL=http://localhost:3006
NEXT_PUBLIC_DEVELOPER_URL=http://localhost:3007

# Backends (NestJS)
AUTH_SERVICE_URL=http://localhost:4000
RH_SERVICE_URL=http://localhost:4001
FINANCE_SERVICE_URL=http://localhost:4002
PROJECTS_SERVICE_URL=http://localhost:4003
DEVOPS_SERVICE_URL=http://localhost:4004
SUPPORT_SERVICE_URL=http://localhost:4005
PAYMENTS_SERVICE_URL=http://localhost:4006
NOTIFICATION_SERVICE_URL=http://localhost:4007
LICENSE_SERVICE_URL=http://localhost:4008
DEVELOPER_SERVICE_URL=http://localhost:4009

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
