{
  "name": "devtechs",
  "version": "0.1.0",
  "private": true,
  "description": "DevTechs monorepo - apps, services and shared packages",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
