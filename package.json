{
  "name": "SZDevs",
  "version": "0.5.0",
  "private": true,
  "description": "SZDevs monorepo - apps, services and shared packages",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @szdevs/web dev",
    "dev:store": "pnpm --filter @szdevs/store dev",
    "dev:services": "turbo run dev --parallel --filter=./services/*",
    "dev:apps": "turbo run dev --parallel --filter=./apps/*",
    "dev:full": "turbo run dev --parallel --filter=./apps/* --filter=./services/*",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=./packages/*",
    "start": "turbo run start --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "pnpm --filter @szdevs/auth-service test:int",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "docs:extract": "node scripts/openapi/extract.mjs",
    "docs:merge": "node scripts/openapi/merge.mjs",
    "docs:generate": "pnpm build && pnpm docs:extract && pnpm docs:merge",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @szdevs/database prisma:generate",
    "db:migrate": "pnpm --filter @szdevs/database prisma:migrate",
    "db:migrate:deploy": "pnpm --filter @szdevs/database prisma:migrate:deploy",
    "db:seed": "pnpm --filter @szdevs/database db:seed",
    "db:studio": "pnpm --filter @szdevs/database prisma:studio",
    "postinstall": "pnpm db:generate",
    "bootstrap": "pnpm install && pnpm build:packages && pnpm db:migrate:deploy && pnpm db:seed",
    "infra:reset": "cd infra && docker compose down -v && docker compose up -d postgres redis && sleep 5 && cd .. && pnpm db:migrate:deploy && pnpm db:seed",
    "infra:reset:redis": "docker exec SZDevs-redis redis-cli FLUSHALL",
    "infra:reset:postgres": "pnpm --filter @szdevs/database prisma migrate reset --force && pnpm db:seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@swc/core": "^1.4.0",
    "@types/node": "^20.12.0",
    "eslint": "^8.57.0",
    "playwright": "^1.59.1",
    "prettier": "^3.2.5",
    "socket.io-client": "^4.7.5",
    "turbo": "^2.9.14",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.1.1",
      "fast-uri": ">=3.1.2",
      "protobufjs": ">=7.5.6",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "fast-xml-builder": ">=1.1.7",
      "js-cookie": ">=3.0.7",
      "basic-ftp": ">=5.3.1"
    }
  }
}
