.auth/
dump.rdb

# Upload scratch directory (runtime artifacts)
services/support-service/uploads/

# TLS certificates (production secrets — never commit)
infra/certs/
*.crt
*.key
*.pem

# Database backups (operational, possibly sensitive)
backups/
