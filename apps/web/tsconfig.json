{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "declaration": false,
    "declarationMap": false,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@szdevs/ui": ["../../packages/ui/src"],
      "@szdevs/ui/*": ["../../packages/ui/src/*"],
      "@szdevs/types": ["../../packages/types/src"],
      "@szdevs/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
