# pnpm workspace configuration
# https://pnpm.io/npmrc

# Use hoisted node_modules so @nestjs/cli can resolve @swc/core and other
# implicit peer dependencies regardless of which service directory it runs from.
# This mirrors npm/yarn behavior and is the recommended setup for NestJS monorepos.
shamefully-hoist=true

# Ensure consistent lockfile across platforms.
strict-peer-dependencies=false
auto-install-peers=true
